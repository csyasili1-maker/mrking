{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/about",
      "dest": "/about.html"
    },
    {
      "src": "/services",
      "dest": "/services.html"
    },
    {
      "src": "/subsidy",
      "dest": "/subsidy.html"
    },
    {
      "src": "/business",
      "dest": "/business.html"
    },
    {
      "src": "/gallery",
      "dest": "/gallery.html"
    },
    {
      "src": "/contact",
      "dest": "/contact.html"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/signup",
      "dest": "/signup.html"
    },
    {
      "src": "/affiliate-panel",
      "dest": "/affiliate-panel.html"
    },
    {
      "src": "/vendor-panel",
      "dest": "/vendor-panel.html"
    },
    {
      "src": "/admin-panel",
      "dest": "/admin-panel.html"
    }
  ]
}
